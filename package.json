{
  "name": "@kubohiroya/turbowarp-asset-manager",
  "version": "0.1.1",
  "author": "Hiroya Kubo <hiroya@cuc.ac.jp>",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "test": "vitest run",
    "docs": "node scripts/generate-readme.mjs",
    "docs:check": "pnpm run docs && git diff --exit-code -- README.md",
    "check": "pnpm run typecheck && npm run test && npm run build && npm run docs:check"
  },
  "devDependencies": {
    "@kubohiroya/vite-plugin-turbowarp-extension": "0.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
